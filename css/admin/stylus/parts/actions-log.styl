table.actions-log {
  margin 15px 0
  padding 0
  border-collapse collapse
  width 99%

  thead {
    th {
      border 0 !important
      padding 5px 10px !important
      font-weight bold !important
    }
  }

  tbody {
    td {
      border 1px solid #000
      padding 5px 10px
      background #eee
      text-align left
    }
  }

  tr {
    &:last-of-type {
      td {
        background #ffd
      }
    }
  }
}

// admin edit-log: deletion badge (admin_table_edit_log.operation = delete)
.operation {
  display inline-block
  margin 0 6px
  padding 1px 6px
  border-radius 3px
  font-size 11px
  line-height 16px
  vertical-align middle

  &--delete {
    background #fdecea
    color #c0392b
  }
}
